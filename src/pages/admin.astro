---
import '../styles/global.css';
export const prerender = false;
---
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Panel administrativo | Sorteo QR</title>
  </head>
  <body>
    <main class="page-shell">
      <header class="page-header">
        <h1>Panel administrativo</h1>
        <p>Genera códigos QR y consulta el estado de los tickets.</p>
      </header>

      <section class="card">
        <h2>Generar QR de participación</h2>
        <p>Este QR envía siempre al mismo formulario de registro. Imprímelo para entregarlo a tus clientes.</p>
        <form id="ticket-form" class="form-grid">
          <label for="label">Etiqueta para imprimir (opcional)</label>
          <input id="label" name="label" type="text" placeholder="Ej. Sorteo feria 2026" />

          <button type="submit" class="button">Generar e imprimir QR</button>
        </form>

        <div id="generate-result" class="result-box"></div>
      </section>

      <section class="card">
        <h2>Resumen rápido</h2>
        <div class="summary-header">
          <div id="summary-list" class="summary-grid"></div>
          <button id="refresh-button" class="button button-secondary">Actualizar</button>
        </div>
      </section>

      <section class="card">
        <h2>Participantes registrados</h2>
        <div id="entries-list" class="ticket-list"></div>
      </section>

      <section class="card">
        <h2>Sorteo</h2>
        <button id="draw-button" class="button">Realizar sorteo</button>
        <div id="draw-result" class="result-box"></div>
      </section>
    </main>

    <script type="module" src="/scripts/admin-client.js"></script>
  </body>
</html>
